# --- required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- optional: model + behaviour ---
# Latest models: claude-opus-4-8 (best), claude-sonnet-4-6 (balanced, default), claude-haiku-4-5 (cheap/fast)
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_STEPS=12
AGENT_TEMPERATURE=0.4

# --- optional: persistent memory location (file store) ---
AGENT_MEMORY_DIR=.agent-memory

# --- optional: HTTP channel ---
PORT=8787
# comma-separated bearer tokens that may call the HTTP agent (empty = open, dev only)
AGENT_API_TOKENS=

# --- optional: Telegram channel ---
TELEGRAM_BOT_TOKEN=
# comma-separated chat ids allowed to talk to the bot (empty = anyone)
TELEGRAM_ALLOWED_CHATS=
